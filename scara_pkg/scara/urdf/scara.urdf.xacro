<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="scara">

<xacro:arg name="interface" default="Position" />

<xacro:include filename="$(find scara)/urdf/joints_pos_and_orient.xacro" />
<xacro:include filename="$(find scara)/urdf/joints_positions_limits.xacro" />
<xacro:include filename="$(find scara)/urdf/joints_vel_effort_limits.xacro" />

<xacro:include filename="$(find scara)/urdf/transmission_interface.xacro" >
  <xacro:arg name="interface" value="$(arg interface)" />
</xacro:include>

<!-- workspace -->
  <link
    name="workspace">
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://scara/meshes/workspace.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0 1 0 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://scara/meshes/workspace.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="joint_workspace"
    type="fixed">
    <origin
      xyz="-1.3 -0.71 0.35 "
      rpy="-1.57 0 0" />
    <parent
      link="base_link" />
    <child
      link="workspace" />
    <axis
      xyz="0 0 0"/>
  </joint>
<!-- workspace -->

